# Copy to .env.production and fill in.
# This file lives in the private instance repo, never in the core.

# --- Release ------------------------------------------------------------
# Which core release we're deploying. Set to a semver tag (1.2.3), a
# release candidate (1.2.3-rc.1), or a sha-XXXXXXXX tag for a pinned
# rollback.
IMAGE_TAG=1.2.3

# --- GCP identifiers ----------------------------------------------------
PROJECT_ID=my-wanderline-instance
REGION=us-west1
SQL_INSTANCE=wanderline-db
GCS_BUCKET=my-wanderline-instance-uploads

# --- Cloud Run services -------------------------------------------------
BACKEND_SERVICE=wanderline-backend
FRONTEND_SERVICE=wanderline-frontend

# --- Optional overrides -------------------------------------------------
# Custom base URL if you've fronted the Cloud Run service with a CDN
# or a mapped domain. Leave empty for the default *.run.app URL.
PUBLIC_BASE_URL=

# Sentry (leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# CORS_ORIGIN — set to the frontend URL after that service is deployed.
# Multiple comma-separated origins are allowed.
CORS_ORIGIN=

# --- Secrets (Secret Manager) -------------------------------------------
# These are NOT stored in .env.production. Instead they're populated in
# Google Secret Manager and referenced by name from the deploy scripts:
#   - session-secret        Random 32+ char string. Rotate to log everyone out.
#   - db-password           Cloud SQL user password.
