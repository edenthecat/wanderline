{
  "name": "@wanderline/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Wanderline backend API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "smoke": "tsx src/scripts/smoke-build.ts",
    "lint:openapi": "tsx src/scripts/lint-openapi.ts",
    "migrate": "sh -c 'node-pg-migrate -d DATABASE_URL -m migrations -t pgmigrations ${1:-up}' --",
    "migrate:create": "node-pg-migrate -d DATABASE_URL -m migrations create"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@sentry/node": "^10.65.0",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0",
    "multer": "^2.0.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yauzl": "^3.4.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@stoplight/spectral-core": "^1.23.1",
    "@stoplight/spectral-rulesets": "^1.22.6",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yauzl": "^3.4.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
