# Wanderline Production Environment Variables
# Copy to .env.production and fill in for local prod testing.
# For Cloud Run, these are set via gcloud or Secret Manager.

# ── Required ─────────────────────────────────────────────────────────────

# PostgreSQL connection.
#
# Either set DATABASE_URL directly (TCP):
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
#
# Or set the parts (recommended on Cloud Run with Cloud SQL Unix socket):
#   DB_USER=wanderline
#   DB_PASSWORD=...           # store in Secret Manager, inject via --set-secrets
#   DB_NAME=wanderline
#   INSTANCE_CONNECTION_NAME=PROJECT:REGION:INSTANCE
DATABASE_URL=
DB_USER=
DB_NAME=
DB_PASSWORD=
INSTANCE_CONNECTION_NAME=

# Long random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
# In production, store in Secret Manager and pass as --set-secrets.
SESSION_SECRET=

# Comma-separated list of origins allowed by CORS.
# Example: https://wanderline-frontend-abc123.run.app,https://wanderline.example.com
CORS_ORIGIN=

# ── Object storage ───────────────────────────────────────────────────────

# Storage backend for audio uploads and build artifacts.
#   "local" (default): files on local filesystem under STORAGE_ROOT
#                      (defaults to /tmp/wanderline-storage)
#   "gcs": Google Cloud Storage (required on Cloud Run since /tmp is ephemeral)
STORAGE_BACKEND=local

# Override the local backend's storage root. Defaults to /tmp/wanderline-storage.
# STORAGE_ROOT=

# GCS bucket name (required when STORAGE_BACKEND=gcs).
# Convention: <project-id>-wanderline-uploads
GCS_BUCKET=

# ── Frontend build-time ──────────────────────────────────────────────────

# Backend URL used by frontend at runtime (nginx proxy target).
# Example: https://wanderline-backend-abc123-uw.a.run.app
BACKEND_URL=

# ── Optional ─────────────────────────────────────────────────────────────

# Override default upload/build directories (Cloud Run only has /tmp).
# UPLOAD_DIR=/tmp/uploads
# BUILDS_DIR=/tmp/exports

# Node environment — should always be "production" in deployed envs.
NODE_ENV=production

# ── Cloud Run only ───────────────────────────────────────────────────────

# Set automatically by Cloud Run; do not configure manually.
# PORT=8080
